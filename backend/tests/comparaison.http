@baseUrl = http://localhost:4000/api

### 0. Connexion
# @name connexion
POST {{baseUrl}}/auth/connexion
Content-Type: application/json

{ "email": "camille@test.fr", "motDePasse": "MotDePasseTest12" }

### 1. Bien
# @name bien
POST {{baseUrl}}/biens
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "adresse": "3 rue de la Comparaison", "codePostal": "69004", "ville": "Lyon", "typeLogement": "Studio" }

### 2. EDL d'entrée
# @name entree
POST {{baseUrl}}/etats-des-lieux
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "idBien": "{{bien.response.body.idBien}}", "typeEdl": "entree", "locataire": { "nom": "Compare", "prenom": "Léa", "email": "lea.compare@test.fr" } }

### 3. Pièce Salon
# @name salon
POST {{baseUrl}}/etats-des-lieux/{{entree.response.body.idEdl}}/pieces
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "libelle": "Salon" }

### 4. Élément Mur (bon état à l'entrée)
POST {{baseUrl}}/pieces/{{salon.response.body.idPiece}}/elements
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "libelle": "Mur principal", "etat": "bonEtat" }

### 5. Élément Fenêtre (neuf à l'entrée)
POST {{baseUrl}}/pieces/{{salon.response.body.idPiece}}/elements
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "libelle": "Fenêtre", "etat": "neuf" }

### 6. Signature bailleur
POST {{baseUrl}}/etats-des-lieux/{{entree.response.body.idEdl}}/signatures
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "roleSignataire": "bailleur", "donneesSignature": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==" }

### 7. Signature locataire → l'entrée est signée (l'e-mail vers l'adresse fictive échouera en logs : normal)
POST {{baseUrl}}/etats-des-lieux/{{entree.response.body.idEdl}}/signatures
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "roleSignataire": "locataire", "donneesSignature": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==" }

### 8. EDL de sortie (pré-rempli)
# @name sortie
POST {{baseUrl}}/etats-des-lieux
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "idBien": "{{bien.response.body.idBien}}", "typeEdl": "sortie", "locataire": { "nom": "Compare", "prenom": "Léa", "email": "lea.compare@test.fr" } }

### 9. Détail de la sortie (pour récupérer les ids copiés)
# @name sortieD
GET {{baseUrl}}/etats-des-lieux/{{sortie.response.body.idEdl}}
Authorization: Bearer {{connexion.response.body.jeton}}

### 10. Le Mur se dégrade → mauvais état
PUT {{baseUrl}}/elements/{{sortieD.response.body.pieces[0].elements[0].idElement}}
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "libelle": "Mur principal", "etat": "mauvaisEtat", "commentaire": "Gros impact au centre" }

### 11. La Fenêtre disparaît de la sortie (→ nonConstate)
DELETE {{baseUrl}}/elements/{{sortieD.response.body.pieces[0].elements[1].idElement}}
Authorization: Bearer {{connexion.response.body.jeton}}

### 12. Une Plinthe apparaît (→ nouveau)
POST {{baseUrl}}/pieces/{{sortieD.response.body.pieces[0].idPiece}}/elements
Authorization: Bearer {{connexion.response.body.jeton}}
Content-Type: application/json

{ "libelle": "Plinthe", "etat": "etatUsage" }

### 13. LA COMPARAISON → attendu 200
GET {{baseUrl}}/etats-des-lieux/{{sortie.response.body.idEdl}}/comparaison
Authorization: Bearer {{connexion.response.body.jeton}}

### 14. Comparaison depuis l'ENTRÉE → attendu 422
GET {{baseUrl}}/etats-des-lieux/{{entree.response.body.idEdl}}/comparaison
Authorization: Bearer {{connexion.response.body.jeton}}