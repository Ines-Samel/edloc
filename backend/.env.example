DATABASE_URL=postgresql://user:password@localhost:5432/nom_de_votre_base_de_données

# Compte administrateur (créé par le script de seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="mot de passe sécurisé"

PORT=4000

JWT_SECRET="votre-clé-secrète-jwt-très-sécurisée"

S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="la clé d'accès"
S3_SECRET_ACCESS_KEY="la clé secrète"
S3_BUCKET="nom-de-votre-bucket"
S3_REGION="auto"

SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=port SMTP (souvent 587 ou 465)
SMTP_USER="le login SMTP affiché"
SMTP_PASS="la clé SMTP"
EMAIL_EXPEDITEUR="EDLoc <ton-adresse-verifiee@exemple.fr>"